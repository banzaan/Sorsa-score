{
  "manifest_version": 3,
  "name": "Corsa Score Injector Premium",
  "version": "3.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.sorsa.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}